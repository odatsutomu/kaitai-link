# ================================================================
# 解体LINK 環境変数
# このファイルを .env.local にコピーして値を入力してください
# Vercel にも同じ値を Environment Variables として登録します
# ================================================================

# ── PostgreSQL（Neon） ────────────────────────────────────────────
# Neon ダッシュボード → Connect → Prisma を選択してコピー
DATABASE_URL="postgresql://neondb_owner:パスワード@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://neondb_owner:パスワード@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# ── Cloudflare R2（画像ストレージ） ───────────────────────────────
R2_ACCOUNT_ID="Cloudflareアカウント画面右下のAccount ID"
R2_ACCESS_KEY_ID="R2 APIトークンのAccess Key"
R2_SECRET_ACCESS_KEY="R2 APIトークンのSecret Key"
R2_KAITAI_BUCKET="kaitai-images"
R2_KAITAI_PUBLIC_URL="https://pub-xxxxxxxxxxxx.r2.dev"

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Cron認証（openssl rand -hex 32 で生成） ───────────────────────
CRON_SECRET="ランダムな64文字以上の文字列"

# ── アプリURL ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://kaitai-link.vercel.app"
