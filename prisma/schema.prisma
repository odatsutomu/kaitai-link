generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── 解体LINK Models ──────────────────────────────────────────────────────────

model KaitaiCompany {
  id               String   @id @default(cuid())
  name             String
  address          String
  phone            String
  adminName        String
  adminEmail       String   @unique
  password1Hash    String
  password2Hash    String
  plan             String   @default("free")
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sessions      KaitaiSession[]
  sites         KaitaiSite[]
  members       KaitaiMember[]
  equipment     KaitaiEquipment[]
  clients       KaitaiClient[]
  expenseLogs   KaitaiExpenseLog[]
  images        KaitaiImage[]
  operationLogs   KaitaiOperationLog[]
  monthlyEvals    KaitaiMonthlyEval[]
  skillCategories  KaitaiSkillCategory[]
  skills           KaitaiSkill[]
  userSkills       KaitaiUserSkill[]
  processors       KaitaiProcessor[]
  processorPrices  KaitaiProcessorPrice[]
}

model KaitaiSession {
  id        String   @id @default(cuid())
  companyId String
  authLevel String   @default("worker")
  token     String   @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime @default(now())

  company KaitaiCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([companyId])
}

model KaitaiSite {
  id             String   @id @default(cuid())
  companyId      String
  clientId       String?
  name           String
  address        String
  status         String   @default("着工前")
  startDate      String?
  endDate        String?
  contractAmount Int      @default(0)
  costAmount     Int      @default(0)
  progressPct    Int      @default(0)
  lat            Float?
  lng            Float?
  structureType  String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company     KaitaiCompany      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenseLogs KaitaiExpenseLog[]
  images      KaitaiImage[]

  @@index([companyId])
}

model KaitaiMember {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  kana        String?
  type        String   @default("直用")   // 直用 | 外注
  company2    String?                      // 外注先会社名
  role        String   @default("作業員")
  birthDate   String?
  hireDate    String?
  address     String?
  emergency   String?
  licenses    String[] @default([])        // ["kaitai","crane",...]
  preYears    Int      @default(0)
  siteCount   Int      @default(0)
  dayRate     Int      @default(0)
  avatar      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company KaitaiCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model KaitaiClient {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  memo        String?
  status      String   @default("active")
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company KaitaiCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model KaitaiEquipment {
  id             String   @id @default(cuid())
  companyId      String
  name           String
  category       String
  type           String
  supplier       String?
  unitPrice      Int      @default(0)
  status         String   @default("待機中")
  returnDeadline String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company KaitaiCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model KaitaiExpenseLog {
  id            String   @id @default(cuid())
  companyId     String
  siteId        String?
  siteName      String?
  category      String
  amount        Int      @default(0)
  description   String?
  reporter      String
  date          String
  memo          String?
  equipmentId   String?
  equipmentName String?
  liters        Float?
  pricePerLiter Float?
  createdAt     DateTime @default(now())

  company KaitaiCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site    KaitaiSite?   @relation(fields: [siteId], references: [id])

  @@index([companyId])
  @@index([siteId])
  @@index([createdAt])
}

model KaitaiImage {
  id         String    @id @default(cuid())
  companyId  String
  siteId     String?
  reportType String?
  r2Key      String
  url        String
  expiresAt  DateTime?
  uploadedBy String
  createdAt  DateTime  @default(now())

  company KaitaiCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site    KaitaiSite?   @relation(fields: [siteId], references: [id])

  @@index([companyId])
  @@index([expiresAt])
}

model KaitaiMonthlyEval {
  id          String   @id @default(cuid())
  companyId   String
  memberId    String
  month       String                         // "2026-04" format
  score1      Int      @default(0)           // 現場実績の総合
  score2      Int      @default(0)           // 会社方針・ルール遵守
  score3      Int      @default(0)           // 責任感・資産管理
  score4      Int      @default(0)           // 後進育成・影響力
  score5      Int      @default(0)           // 向上心・自己研鑽
  memo        String?                        // 昇給検討用・非公開メモ
  confirmed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company KaitaiCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, memberId, month])
  @@index([companyId])
  @@index([memberId])
}

model KaitaiSkillCategory {
  id        String   @id @default(cuid())
  companyId String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company KaitaiCompany      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  skills  KaitaiSkill[]

  @@index([companyId])
}

model KaitaiSkill {
  id         String   @id @default(cuid())
  companyId  String
  categoryId String
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company    KaitaiCompany       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category   KaitaiSkillCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userSkills KaitaiUserSkill[]

  @@index([companyId])
  @@index([categoryId])
}

model KaitaiUserSkill {
  id         String   @id @default(cuid())
  companyId  String
  memberId   String
  skillId    String
  taughtBy   String?           // memberId of teacher
  achievedAt DateTime @default(now())

  company KaitaiCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  skill   KaitaiSkill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([companyId, memberId, skillId])
  @@index([companyId])
  @@index([memberId])
  @@index([skillId])
}

model KaitaiProcessor {
  id        String   @id @default(cuid())
  companyId String
  name      String
  address   String?
  lat       Float?
  lng       Float?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company KaitaiCompany          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  prices  KaitaiProcessorPrice[]

  @@index([companyId])
}

model KaitaiProcessorPrice {
  id          String   @id @default(cuid())
  companyId   String
  processorId String
  wasteType   String
  unit        String   @default("kg")
  unitPrice   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   KaitaiCompany   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  processor KaitaiProcessor @relation(fields: [processorId], references: [id], onDelete: Cascade)

  @@unique([processorId, wasteType])
  @@index([companyId])
  @@index([processorId])
}

model KaitaiOperationLog {
  id        String   @id @default(cuid())
  companyId String?
  action    String
  user      String
  device    String?
  siteId    String?
  createdAt DateTime @default(now())

  company KaitaiCompany? @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([createdAt])
}
