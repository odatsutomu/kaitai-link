generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── 解体LINK Models ──────────────────────────────────────────────────────────

model KaitaiCompany {
  id               String   @id @default(cuid())
  name             String
  address          String
  phone            String
  adminName        String
  adminEmail       String   @unique
  password1Hash    String
  password2Hash    String
  plan             String   @default("free")
  stripeCustomerId String?
  featureToggles   Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sessions        KaitaiSession[]
  sites           KaitaiSite[]
  members         KaitaiMember[]
  equipment       KaitaiEquipment[]
  clients         KaitaiClient[]
  expenseLogs     KaitaiExpenseLog[]
  images          KaitaiImage[]
  operationLogs   KaitaiOperationLog[]
  monthlyEvals    KaitaiMonthlyEval[]
  skillCategories KaitaiSkillCategory[]
  skills          KaitaiSkill[]
  userSkills      KaitaiUserSkill[]
  processors      KaitaiProcessor[]
  processorPrices KaitaiProcessorPrice[]
  contractData     KaitaiContractData[]
  wasteCategories  KaitaiWasteCategory[]
  wasteDispatches  KaitaiWasteDispatch[]
}

model KaitaiSession {
  id        String   @id @default(cuid())
  companyId String
  authLevel String   @default("worker")
  token     String   @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime @default(now())

  company KaitaiCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([companyId])
}

model KaitaiSite {
  id             String   @id @default(cuid())
  companyId      String
  clientId       String?
  name           String
  address        String
  status         String   @default("着工前")
  startDate      String?
  endDate        String?
  contractAmount Int      @default(0)
  paidAmount     Int      @default(0)
  costAmount     Int      @default(0)
  progressPct    Int      @default(0)
  lat            Float?
  lng            Float?
  structureType  String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company      KaitaiCompany       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenseLogs  KaitaiExpenseLog[]
  images       KaitaiImage[]
  contractData KaitaiContractData?
  payments     KaitaiPayment[]

  @@index([companyId])
}

model KaitaiPayment {
  id        String   @id @default(cuid())
  companyId String
  siteId    String
  amount    Int
  date      String        // YYYY-MM-DD
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site KaitaiSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([siteId])
}

model KaitaiMember {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  kana        String?
  type        String   @default("直用")   // 直用 | 外注
  company2    String?                      // 外注先会社名
  role        String   @default("作業員")
  birthDate   String?
  hireDate    String?
  address     String?
  emergency   String?
  licenses    String[] @default([])        // ["kaitai","crane",...]
  preYears    Int      @default(0)
  siteCount   Int      @default(0)
  dayRate     Int      @default(0)
  avatar      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company KaitaiCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model KaitaiClient {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  memo        String?
  contacts    Json?                         // [{name, phone, role?}]
  status      String   @default("active")
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company KaitaiCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model KaitaiEquipment {
  id             String   @id @default(cuid())
  companyId      String
  name           String
  category       String
  type           String
  supplier       String?
  unitPrice      Int      @default(0)
  status         String   @default("待機中")
  returnDeadline String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company KaitaiCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model KaitaiExpenseLog {
  id            String   @id @default(cuid())
  companyId     String
  siteId        String?
  siteName      String?
  category      String
  amount        Int      @default(0)
  description   String?
  reporter      String
  date          String
  memo          String?
  equipmentId   String?
  equipmentName String?
  liters        Float?
  pricePerLiter Float?
  createdAt     DateTime @default(now())

  company KaitaiCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site    KaitaiSite?   @relation(fields: [siteId], references: [id])

  @@index([companyId])
  @@index([siteId])
  @@index([createdAt])
}

model KaitaiImage {
  id         String    @id @default(cuid())
  companyId  String
  siteId     String?
  reportType String?
  r2Key      String
  url        String
  expiresAt  DateTime?
  uploadedBy String
  createdAt  DateTime  @default(now())

  company KaitaiCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site    KaitaiSite?   @relation(fields: [siteId], references: [id])

  @@index([companyId])
  @@index([expiresAt])
}

model KaitaiMonthlyEval {
  id          String   @id @default(cuid())
  companyId   String
  memberId    String
  month       String                         // "2026-04" format
  score1      Int      @default(0)           // 現場実績の総合
  score2      Int      @default(0)           // 会社方針・ルール遵守
  score3      Int      @default(0)           // 責任感・資産管理
  score4      Int      @default(0)           // 後進育成・影響力
  score5      Int      @default(0)           // 向上心・自己研鑽
  memo        String?                        // 昇給検討用・非公開メモ
  confirmed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company KaitaiCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, memberId, month])
  @@index([companyId])
  @@index([memberId])
}

model KaitaiSkillCategory {
  id        String   @id @default(cuid())
  companyId String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company KaitaiCompany      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  skills  KaitaiSkill[]

  @@index([companyId])
}

model KaitaiSkill {
  id         String   @id @default(cuid())
  companyId  String
  categoryId String
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company    KaitaiCompany       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category   KaitaiSkillCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userSkills KaitaiUserSkill[]

  @@index([companyId])
  @@index([categoryId])
}

model KaitaiUserSkill {
  id         String   @id @default(cuid())
  companyId  String
  memberId   String
  skillId    String
  taughtBy   String?           // memberId of teacher
  achievedAt DateTime @default(now())

  company KaitaiCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  skill   KaitaiSkill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([companyId, memberId, skillId])
  @@index([companyId])
  @@index([memberId])
  @@index([skillId])
}

model KaitaiProcessor {
  id        String   @id @default(cuid())
  companyId String
  name      String
  address   String?
  lat       Float?
  lng       Float?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company KaitaiCompany          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  prices  KaitaiProcessorPrice[]

  @@index([companyId])
}

model KaitaiProcessorPrice {
  id          String   @id @default(cuid())
  companyId   String
  processorId String
  wasteType   String
  unit        String   @default("t")
  unitPrice   Int      @default(0)
  direction   String   @default("cost")  // "cost" | "buyback"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   KaitaiCompany   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  processor KaitaiProcessor @relation(fields: [processorId], references: [id], onDelete: Cascade)

  @@unique([processorId, wasteType])
  @@index([companyId])
  @@index([processorId])
}

model KaitaiWasteCategory {
  id        String   @id @default(cuid())
  companyId String
  name      String
  sortOrder Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  company KaitaiCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
}

model KaitaiWasteDispatch {
  id          String   @id @default(cuid())
  companyId   String
  siteId      String
  siteName    String
  date        String
  wasteType   String
  quantity    Float
  unit        String
  processorId String?
  processorName String?
  cost        Int      @default(0)
  direction   String   @default("cost")  // "cost" | "buyback"
  reporter    String
  createdAt   DateTime @default(now())

  company KaitaiCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([siteId, date])
}

model KaitaiOperationLog {
  id        String   @id @default(cuid())
  companyId String?
  action    String
  user      String
  device    String?
  siteId    String?
  imageIds  Json     @default("[]")
  createdAt DateTime @default(now())

  company KaitaiCompany? @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([createdAt])
}

model KaitaiContractData {
  id             String   @id @default(cuid())
  companyId      String
  siteId         String   @unique

  // Section 1: 顧客・契約基本情報
  clientName     String?
  clientZip      String?
  clientAddress  String?
  clientContact  String?
  paymentTerms   String?
  expiryDays     Int      @default(30)
  projectName    String?
  projectAddress String?

  // Section 2: 見積・請求明細
  estimateItems  Json     @default("[]")
  invoiceItems   Json     @default("[]")
  notes          String?

  // Section 3: 建物滅失登記用データ
  landAddress    String?
  houseNo        String?
  structureKind  String?
  floor1Area     String?
  floor2Area     String?
  floor3Area     String?

  // Section 4: 工事完了報告
  photoIds       Json     @default("[]")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company KaitaiCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site    KaitaiSite    @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ─── 清掃LINK Models ──────────────────────────────────────────────────────────

model SeisouCompany {
  id               String   @id @default(cuid())
  name             String
  address          String
  phone            String
  adminName        String
  adminEmail       String   @unique
  password1Hash    String
  password2Hash    String
  password3Hash    String?
  plan             String   @default("free")
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sessions           SeisouSession[]
  sites              SeisouSite[]
  members            SeisouMember[]
  clients            SeisouClient[]
  equipment          SeisouEquipment[]
  shifts             SeisouShift[]
  workSessions       SeisouWorkSession[]
  irregularReports   SeisouIrregularReport[]
  expenseLogs        SeisouExpenseLog[]
  images             SeisouImage[]
  threads            SeisouThread[]
  messages           SeisouMessage[]
  checklistTemplates SeisouChecklistTemplate[]
  operationLogs      SeisouOperationLog[]
}

model SeisouSession {
  id        String   @id @default(cuid())
  companyId String
  authLevel String   @default("worker")
  token     String   @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime @default(now())

  company SeisouCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([companyId])
}

model SeisouSite {
  id             String   @id @default(cuid())
  companyId      String
  clientId       String?
  name           String
  address        String
  status         String   @default("作業前")
  startDate      String?
  endDate        String?
  contractAmount Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company          SeisouCompany           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client           SeisouClient?           @relation(fields: [clientId], references: [id])
  shifts           SeisouShift[]
  workSessions     SeisouWorkSession[]
  irregularReports SeisouIrregularReport[]
  expenseLogs      SeisouExpenseLog[]
  images           SeisouImage[]

  @@index([companyId])
  @@index([clientId])
}

model SeisouMember {
  id        String   @id @default(cuid())
  companyId String
  name      String
  role      String   @default("worker")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company SeisouCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model SeisouClient {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  memo        String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company SeisouCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sites   SeisouSite[]

  @@index([companyId])
}

model SeisouEquipment {
  id             String   @id @default(cuid())
  companyId      String
  name           String
  category       String
  type           String
  supplier       String?
  unitPrice      Int      @default(0)
  status         String   @default("待機中")
  returnDeadline String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company     SeisouCompany      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenseLogs SeisouExpenseLog[]

  @@index([companyId])
}

model SeisouShift {
  id        String   @id @default(cuid())
  companyId String
  staffName String
  date      String
  startTime String
  endTime   String
  siteId    String?
  siteName  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      SeisouCompany       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site         SeisouSite?         @relation(fields: [siteId], references: [id])
  workSessions SeisouWorkSession[]

  @@index([companyId])
  @@index([date])
  @@index([siteId])
}

model SeisouWorkSession {
  id          String    @id @default(cuid())
  companyId   String
  staffName   String
  shiftId     String?
  siteId      String?
  siteName    String?
  date        String
  status      String    @default("idle")
  travelStartAt DateTime?
  arrivedAt     DateTime?
  workStartAt   DateTime?
  workEndAt     DateTime?
  notes       String?
  imageUrls   String[]  @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company            SeisouCompany             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shift              SeisouShift?              @relation(fields: [shiftId], references: [id])
  site               SeisouSite?               @relation(fields: [siteId], references: [id])
  irregularReports   SeisouIrregularReport[]
  checklistResponses SeisouChecklistResponse[]

  @@index([companyId])
  @@index([date])
  @@index([staffName])
  @@index([siteId])
}

model SeisouIrregularReport {
  id          String   @id @default(cuid())
  companyId   String
  sessionId   String?
  siteId      String?
  siteName    String?
  staffName   String
  category    String
  description String
  severity    String   @default("low")
  imageUrls   String[] @default([])
  createdAt   DateTime @default(now())

  company     SeisouCompany      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workSession SeisouWorkSession? @relation(fields: [sessionId], references: [id])
  site        SeisouSite?        @relation(fields: [siteId], references: [id])

  @@index([companyId])
  @@index([createdAt])
}

model SeisouExpenseLog {
  id            String  @id @default(cuid())
  companyId     String
  siteId        String?
  siteName      String?
  equipmentId   String?
  equipmentName String?
  category      String
  amount        Int     @default(0)
  description   String?
  reporter      String
  date          String
  memo          String?
  liters        Float?
  pricePerLiter Float?
  createdAt     DateTime @default(now())

  company   SeisouCompany    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site      SeisouSite?      @relation(fields: [siteId], references: [id])
  equipment SeisouEquipment? @relation(fields: [equipmentId], references: [id])

  @@index([companyId])
  @@index([siteId])
  @@index([createdAt])
}

model SeisouImage {
  id         String    @id @default(cuid())
  companyId  String
  siteId     String?
  reportType String?
  r2Key      String
  url        String
  expiresAt  DateTime?
  uploadedBy String
  createdAt  DateTime  @default(now())

  company SeisouCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site    SeisouSite?   @relation(fields: [siteId], references: [id])

  @@index([companyId])
  @@index([expiresAt])
}

model SeisouThread {
  id          String   @id @default(cuid())
  companyId   String
  title       String
  description String?
  createdBy   String
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company  SeisouCompany   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messages SeisouMessage[]

  @@index([companyId])
}

model SeisouMessage {
  id        String   @id @default(cuid())
  threadId  String
  companyId String
  staffName String
  body      String
  createdAt DateTime @default(now())

  company SeisouCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  thread  SeisouThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([companyId])
  @@index([createdAt])
}

model SeisouChecklistTemplate {
  id        String   @id @default(cuid())
  companyId String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company SeisouCompany       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items   SeisouChecklistItem[]

  @@index([companyId])
}

model SeisouChecklistItem {
  id         String   @id @default(cuid())
  templateId String
  label      String
  required   Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  template  SeisouChecklistTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  responses SeisouChecklistResponse[]

  @@index([templateId])
}

model SeisouChecklistResponse {
  id        String  @id @default(cuid())
  sessionId String
  itemId    String
  checked   Boolean @default(false)
  note      String?
  createdAt DateTime @default(now())

  workSession SeisouWorkSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  item        SeisouChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([itemId])
}

model SeisouOperationLog {
  id        String   @id @default(cuid())
  companyId String?
  action    String
  user      String
  siteId    String?
  device    String?
  createdAt DateTime @default(now())

  company SeisouCompany? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([createdAt])
}
